    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "YANGSHEEP DESIGN",
            "homepage": "https://yangsheep.com.tw"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "YangSheep\\ChatWidgets\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
